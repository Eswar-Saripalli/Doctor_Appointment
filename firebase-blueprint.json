{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile in the system, either a patient or a doctor.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Detailed profile for a doctor.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "specialty": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "availability": {
          "type": "object",
          "description": "Weekly availability schedule"
        },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "name", "specialty"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A booked medical appointment.",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "type": { "type": "string", "enum": ["in-person", "video"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "time", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account information and roles."
    },
    "/doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Public doctor profiles available for booking."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments booked by patients with doctors."
    }
  }
}
