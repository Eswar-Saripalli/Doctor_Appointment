rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
               data.uid == request.auth.uid &&
               data.email is string &&
               data.role in ['patient', 'doctor'] &&
               data.createdAt == request.time;
      }

      allow get: if isOwner(userId);
      allow create: if isSignedIn() && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    incoming().role == existing().role &&
                    incoming().createdAt == existing().createdAt;
    }

    // --- Doctors Collection ---
    match /doctors/{doctorId} {
      function isValidDoctor(data) {
        return data.keys().hasAll(['uid', 'name', 'specialty']) &&
               data.uid == doctorId &&
               data.name is string && data.name.size() <= 100 &&
               data.specialty is string && data.specialty.size() <= 100;
      }

      allow list: if true; 
      allow get: if true;
      allow create: if isOwner(doctorId) && isValidDoctor(incoming());
      allow update: if isOwner(doctorId) && isValidDoctor(incoming()) &&
                    incoming().uid == existing().uid;
    }

    // --- Appointments Collection ---
    match /appointments/{appointmentId} {
      function isValidAppointment(data) {
        return data.keys().hasAll(['patientId', 'doctorId', 'date', 'time', 'status', 'createdAt']) &&
               data.patientId == request.auth.uid &&
               data.doctorId is string &&
               data.date is string &&
               data.time is string &&
               data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
               data.createdAt == request.time;
      }

      allow list: if isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid);
      allow get: if isSignedIn() && (resource.data.patientId == request.auth.uid || resource.data.doctorId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(appointmentId) && isValidAppointment(incoming());
      allow update: if isSignedIn() && (existing().patientId == request.auth.uid || existing().doctorId == request.auth.uid) &&
                    incoming().patientId == existing().patientId &&
                    incoming().doctorId == existing().doctorId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'notes']);
    }
  }
}
